# Required
TELEGRAM_TOKEN=your-telegram-bot-token
OPENAI_API_KEY=your-openai-api-key
OWNER_CHAT_ID=your-telegram-chat-id

# Personalization (all optional - defaults shown)
# BOT_OWNER_NAME=YourName
# BOT_LANGUAGE=English
# NEWS_DIGEST_LANGUAGE=English  # defaults to BOT_LANGUAGE if unset
# USER_TIMEZONE=UTC
# MODEL=gpt-4o
# BOT_USER_AGENT=TelegramAIBot/1.0

# Pricing per 1M tokens (match your model's pricing)
# PRICE_INPUT_PER_M=2.50
# PRICE_OUTPUT_PER_M=10.00

# Google integrations (optional - needed for Gmail, Calendar, Image gen, Voice)
# GOOGLE_AI_API_KEY=your-google-ai-api-key
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
